{
  "name": "workflow-studio",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint --fix",
    "test": "pnpm -r test",
    "test:cov": "pnpm -r test:cov",
    "db:build": "pnpm --filter @workflow-studio/db build",
    "db:generate": "pnpm --filter @workflow-studio/db generate",
    "db:migrate": "pnpm --filter @workflow-studio/db migrate",
    "db:reset": "pnpm --filter @workflow-studio/db reset",
    "db:seed": "pnpm --filter @workflow-studio/db seed",
    "prepare": "husky",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.34.4",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  }
}
